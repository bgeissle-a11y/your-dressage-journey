rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Authenticated users can read/write their own documents
    // All collections use userId field to scope data per user

    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;

      match /weeklyFocus/{weekId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /weeklyContext/{weekId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /gptProgress/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /journeyMap/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /riderProfiles/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /horseProfiles/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /reflections/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /debriefs/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Micro-debriefs — lightweight ride entries; Cloud Function writes the
    // empatheticResponse field after submission via admin SDK (bypasses rules).
    match /microDebriefs/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Fresh Start submissions — re-onboarding entries; Cloud Function writes
    // the empatheticResponse field after submission via admin SDK.
    match /freshStarts/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /journeyEvents/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /observations/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /eventPrepPlans/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /showPreparations/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;

      // Readiness Snapshot subcollection — written by Cloud Function, read by client
      match /readinessSnapshot/{snapId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/showPreparations/$(docId)).data.userId == request.auth.uid;
      }
    }

    match /physicalAssessments/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /riderAssessments/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /technicalPhilosophicalAssessments/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /horseHealthEntries/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /riderHealthEntries/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /lessonNotes/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /riderToolkitEntries/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;

      // Visualization script sessions subcollection
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/riderToolkitEntries/$(docId)).data.userId == request.auth.uid;
      }
    }

    // Registration consent (Terms of Service / Privacy Policy acknowledgment).
    // Immutable audit record: created once at registration, never modified or deleted.
    // Firestore unions all matching rule grants, so the generic /settings/{document}
    // rule below explicitly excludes `consent` to keep this write-once.
    match /riders/{userId}/settings/consent {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if false;
    }

    // Rider settings (preferences, notifications, privacy).
    // Excludes `consent`, which has its own immutable rule above.
    match /riders/{userId}/settings/{document} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId
                         && document != 'consent';
    }

    // Pre-Ride Ritual subcollection
    match /riders/{userId}/preRideRitual/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rider coaches subcollection
    match /riders/{userId}/coaches/{coachId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Coach briefs — written by Cloud Function, read-only by the rider
    match /riders/{userId}/coachBriefs/{briefId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // First Light — inaugural AI coaching artifact.
    // `current` doc holds the active First Light; auto-id docs hold the
    // history (prior generations after a regenerate). Both written exclusively
    // by Cloud Functions (admin SDK bypasses rules); read-only by the rider.
    match /riders/{userId}/firstLight/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Onboarding flags — UI side-effect flags (e.g. firstReflectionIntroShownAt).
    // Client-writable since flag-setting is a UI side-effect of the rider
    // clicking through onboarding moments — no AI cost or sensitive write involved.
    match /riders/{userId}/onboardingFlags/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Analysis cache — written by Cloud Functions (admin SDK bypasses rules),
    // read-only by the authenticated user for weekly focus snapshots
    match /analysisCache/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Journey Map dashboard summary — written by Cloud Function,
    // read-only by the authenticated user for the dashboard snapshot card
    match /analysis/journeyMap/users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Cycle state — written by Cloud Functions (admin SDK bypasses rules),
    // read-only by the authenticated user for cycle tracking
    match /grandPrixThinkingCycle/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }
    match /physicalGuidanceCycle/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Generation status — written by Cloud Functions (admin SDK bypasses rules),
    // read-only by the authenticated user for real-time progress tracking
    match /generationStatus/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // Usage logs — written by Cloud Functions (admin SDK bypasses rules),
    // no client read/write access (admin queries via Cloud Function)
    match /usageLogs/{docId} {
      allow read, write: if false;
    }

    // Usage budgets — per-user daily API call counters, managed by Cloud Functions only
    match /usageBudgets/{uid} {
      allow read, write: if false;
    }

    // IC cohort counter — public read so the Pricing page can show live
    // spots-remaining; written exclusively by Cloud Functions (admin SDK).
    match /admin/icCohort {
      allow read: if true;
      allow write: if false;
    }

    // Stripe webhook event dedupe ledger — written exclusively by the
    // stripeWebhook Cloud Function (admin SDK bypasses rules). No client
    // read/write access; client never needs to see this. Consider adding
    // a Firestore TTL policy on this collection (~30 days) to bound growth.
    match /stripeWebhookEvents/{eventId} {
      allow read, write: if false;
    }
  }
}
