# Anthropic API Key for AI coaching features
# Get your key from: https://console.anthropic.com/settings/keys
#
# For local development (Firebase Emulator):
#   Copy this file to .env and fill in your actual key
#
# For production deployment:
#   Use Firebase Functions Secrets:
#   firebase functions:secrets:set ANTHROPIC_API_KEY
#
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Sentry Error Tracking (get DSN from https://sentry.io → Project Settings → Client Keys)
SENTRY_DSN=your-sentry-dsn-here

# 30-Day Cycle — Top Tier Token Budgets (LEGACY — superseded by TOKENS_* below)
# Retained as a no-op so existing deployments don't break on env load. The
# canonical per-output budgets live in `functions/lib/tokenBudgets.js`.
PHYSICAL_GPT_TOP_TIER_MAX_TOKENS=6000
PHYSICAL_PROTOCOL_TOP_TIER_MAX_TOKENS=5000
PHYSICAL_AWARENESS_TOP_TIER_MAX_TOKENS=5000

# Regeneration cooldown in hours (GPT/Physical mid-cycle, default 2)
REGEN_COOLDOWN_HOURS=2

# Multi-Voice cooldown (Token Budget Spec v2 §Part 6 #5). Baseline 4 hours
# across all tiers. Separate knob from REGEN_COOLDOWN_HOURS above. Reserve
# Lever 1 will widen this to 8h at Medium without a code change.
MULTIVOICE_COOLDOWN_HOURS=4

# L2 Opus monthly soft cap (Spec §Part 6 #4). Trajectory generations are
# capped per-user per calendar month — set 0 to disable. Each generation
# counts as 1 (L2-1 Opus call). Default 4.
GPT_L2_OPUS_MONTHLY_CAP=4

# ─── Per-output max_tokens overrides (Token Budget Spec v2) ──────────────────
# Defaults live in functions/lib/tokenBudgets.js (per spec). Setting any of
# these overrides the spec value at runtime — useful for emergency trims
# without a deploy. Leave commented out to inherit spec.
# TOKENS_COACHING_VOICE=2500
# TOKENS_COACHING_QUICK_INSIGHTS=2000
# TOKENS_COACHING_PRECIS=400
# TOKENS_JOURNEY_MAP_SYNTHESIS=4000
# TOKENS_JOURNEY_MAP_NARRATIVE=2000
# TOKENS_JOURNEY_MAP_VISUALIZATION=2000
# TOKENS_GPT_L1=6000
# TOKENS_GPT_L2=4000
# TOKENS_PHYSICAL_PROTOCOL=5000
# TOKENS_PHYSICAL_AWARENESS=5000
# TOKENS_EVENT_PLANNER=3000
# TOKENS_VISUALIZATION_SCRIPT=2000
# TOKENS_READINESS_SNAPSHOT=2500

# Tier cost budgets — YDJ_Pricing_Discounts_Consolidation_v2.md Part 3
# Monthly cost ceilings per subscription tier (USD).
TIER_WORKING_MONTHLY_BUDGET_USD=10
TIER_MEDIUM_MONTHLY_BUDGET_USD=40
TIER_EXTENDED_MONTHLY_BUDGET_USD=80

# Weekly cost caps (USD). Per spec, the $20 weekly cap applies to Medium and
# Extended only — Working has no weekly cap (the monthly ceiling alone gates).
TIER_MEDIUM_WEEKLY_BUDGET_USD=20
TIER_EXTENDED_WEEKLY_BUDGET_USD=20

# Backstop weekly budget for users without a paid tier (free pilot, none).
DEFAULT_WEEKLY_BUDGET_USD=20

# ─── Show Planner — Bi-Weekly Content Trigger ───────────────────────────────
# Token Budget Spec v2 Lever 2. The onSchedule trigger fires every 14 days
# regardless of this flag, but the handler returns 0-cost when disabled.
# Set to "true" to enable bi-weekly content generation on active show plans.
# Default: disabled, so a fresh deploy doesn't surprise-bill the user.
SHOW_PLANNER_BIWEEKLY_ENABLED=false

# Stripe
# For local development: set here
# For production: firebase functions:secrets:set STRIPE_SECRET_KEY
#                 firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here
